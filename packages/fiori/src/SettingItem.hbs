<div class="ui5-setting-item">
	<header class="ui5-setting-item-header">
		{{#if _isPhone}}
			<ui5-button icon="nav-back" design="Transparent" @click={{_onBackClick}}></ui5-button>
		{{/if}}

		<ui5-title level="H4" size="H4">{{headerTitle}}</ui5-title>
	</header>

	{{#if _shouldHaveTabs}}
		{{> tabbedContent}}
	{{else}}
		{{#each views}}
			<slot name="{{this._individualSlot}}" />
		{{/each}}
	{{/if}}
</div>

{{#*inline "tabbedContent"}}
	<ui5-tabcontainer  content-background-design="Transparent">
		{{#each views}}
			<ui5-tab text={{text}}>
				<slot name="{{this._individualSlot}}" />
			</ui5-tab>
		{{/each}}
	</ui5-tabcontainer>
{{/inline}}