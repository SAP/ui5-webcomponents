<ui5-dialog .open={{open}}>
	<div class="ui5-profile-menu-user" slot="header">
		{{#if _selectedUser}}
			<ui5-avatar size="L">
				<img src={{_selectedUser.avatar}}/>
				<ui5-tag slot="badge" wrapping-type="None">
					<ui5-icon slot="icon" name="edit"></ui5-icon>
				</ui5-tag>
			</ui5-avatar>
			<ui5-title>{{_selectedUser.text}}</ui5-title>
			<ui5-text>{{_selectedUser.subtitle1}}</ui5-text>
			<ui5-text>{{_selectedUser.subtitle2}}</ui5-text>
			<ui5-button icon="user-settings">Manage Account</ui5-button>
		{{/if}}
	</div>
	<ui5-panel collapsed>
		<div slot="header" class="ui5-profile-menu-user-header">
			<ui5-title slot="header" level="H4">Other Accounts ({{_otherUsers.length}})</ui5-title>
			<ui5-button slot="header" design="Transparent" icon="add-employee" />
		</div>
		<ui5-list>
			{{#each _otherUsers}}
				<ui5-li>
					<ui5-avatar slot="image"size="XS"><img src={{this.avatar}}/></ui5-avatar>
					<ui5-title>{{text}}</ui5-title>
					<ui5-label>{{subtitle1}}</ui5-label>
					</br>
					<ui5-label>{{subtitle2}}</ui5-label>
				</ui5-li>
			{{/each}}
		</ui5-list>
	</ui5-panel>

	<ui5-list separators="None">
	{{#each menuItems}}
		{{#if this.separator}}
			<div class="ui5-profile-menu-separator"></div>
		{{/if}}
		<ui5-li icon={{this.icon}}>{{this.text}}</ui5-li>
	{{/each}}
	</ui5-list>

</ui5-dialog>