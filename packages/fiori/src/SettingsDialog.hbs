<div class="ui5-settings-dialog" >

	<div style="border-right-color: rgba(63, 81, 97, .2); border-right-style: solid; display:inline-block">
		<ui5-navigation-layout id="nl1">

		{{#if headerTitle}}
			<ui5-title slot="header" level="H2" size="H2">{{headerTitle}}</ui5-title>
		{{/if}}
		{{#if showSearchField}}
			<ui5-input slot="header" placeholder="Search" type="Search">
				<ui5-icon id="searchFieldIcon" slot="icon" name="search"></ui5-icon>
			</ui5-input>
		{{/if}}

		<ui5-side-navigation slot="sideContent" @selection-change={{setSelectedItem}}>
			{{#each items}}
				{{#if this.fixedItem}}
					<ui5-side-navigation-item slot="fixedItems" text={{this.text}} tooltip={{this.tooltip}}  href="#{{this.slot.name}}" icon={{this.icon}} .mappedItem={{this}} ?selected={{this.selected}}></ui5-side-navigation-item>
				{{else}}
					<ui5-side-navigation-item text={{this.text}} tooltip={{this.tooltip}} href="#{{this.slot.name}}" icon={{this.icon}} .mappedItem={{this}} ?selected={{this.selected}}></ui5-side-navigation-item>
				{{/if}}
			{{/each}}
		</ui5-side-navigation>

		<div class="content">
			{{#each items}}
				<div id={{this.slot.name}} class="contentItem">
					<ui5-title level="H3" size="H3">{{this.headerTitle}}</ui5-title>
				</div>
				<slot name="{{this._effectiveSlotName}}"></slot>
			{{/each}}
		</div>
		</ui5-navigation-layout>
	</div>

	<div class="footer">
		<div role="separator" class="ui5-setting-spacer" style="margin: 0.25rem; height: 0.25rem; background-color: rgba(63,81,97,.2);"></div>
		<ui5-button design="Transparent">Close</ui5-button>
	</div>
</div>